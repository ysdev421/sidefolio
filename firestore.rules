rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // 存在しないドキュメント(resource==null)への getDoc も許可するreadルール
    function readAllowed() {
      return request.auth != null && (resource == null || request.auth.uid == resource.data.userId);
    }

    match /products/{docId} {
      allow read: if readAllowed();
      allow update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /sales/{docId} {
      allow read: if readAllowed();
      allow update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /sale_batches/{docId} {
      allow read: if readAllowed();
      allow update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /sale_batch_items/{docId} {
      allow read: if readAllowed();
      allow update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /product_templates/{docId} {
      allow read: if request.auth != null;
      allow update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /purchase_location_settings/{docId} {
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    match /jan_master/{janCode} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.janCode == janCode
        && request.resource.data.productName is string;
      allow delete: if false;
    }

    match /user_jan_usage/{docId} {
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /gift_cards/{docId} {
      allow read: if readAllowed();
      allow update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /sale_location_settings/{docId} {
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    match /product_masters/{docId} {
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /expenses/{docId} {
      allow read: if readAllowed();
      allow update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /status_batch_logs/{docId} {
      allow read: if readAllowed();
      allow update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /point_site_redemptions/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /kaitoriPriceHistory/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /keikoji_contracts/{docId} {
      allow read: if readAllowed();
      allow update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
  }
}
